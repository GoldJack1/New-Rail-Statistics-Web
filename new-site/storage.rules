rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /message-centre/{year}/{month}/{fileName} {
      allow read, write: if request.auth != null;
    }

    match /station-exports/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
