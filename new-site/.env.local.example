# Rail Statistics — Next.js environment variables
#
# Copy to .env.local and fill in. Never commit .env.local.
#
# Vite's `VITE_*` client-exposed prefix becomes Next.js's `NEXT_PUBLIC_*`.
# Server-only secrets get no prefix and must only be read inside Route Handlers
# (app/api/**/route.ts), never in Client Components.

# --- Firebase (client-safe — Phase 2) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# --- Dev / feature flags (client-safe) ---
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
NEXT_PUBLIC_USE_LOCAL_DATA_ONLY=false
NEXT_PUBLIC_LOCAL_DEV_LOGIN_BYPASS=false
NEXT_PUBLIC_USE_OSM_PROXY=
# NEXT_PUBLIC_FIREBASE_APP_CHECK_DISABLED=false
# NEXT_PUBLIC_LOCAL_AUTH_EMAIL=
# NEXT_PUBLIC_LOCAL_AUTH_PASSWORD=
# NEXT_PUBLIC_MASTER_PUBLISH_EMAIL=wingatejack2021@gmail.com
# NEXT_PUBLIC_REQUIRE_REAUTH_FOR_SENSITIVE_ACTIONS=
# NEXT_PUBLIC_DARWIN_STARTUP_MAX_WAIT_MS=600000

# --- Darwin Netlify proxy (server-only — Phase 2) ---
# DARWIN_API_ORIGIN=https://api-darwin.railstatistics.co.uk
# DARWIN_API_KEY=
# DARWIN_UK_ONLY=true

# --- Darwin LDBWS (server-only) ---
# DARWIN_LDBWS_API_KEY=
# DARWIN_LDBWS_CONSUMER_KEY=
# DARWIN_LDBWS_CONSUMER_SECRET=
# DARWIN_SERVICE_DETAILS_API_KEY=
# DARWIN_SERVICE_DETAILS_CONSUMER_KEY=
# DARWIN_SERVICE_DETAILS_CONSUMER_SECRET=

# --- Darwin Push Port / Kafka (VM / darwin-local-test only — not Netlify web) ---
# DARWIN_PUSH_CONSUMER_GROUP=
# DARWIN_PUSH_USERNAME=
# DARWIN_PUSH_PASSWORD=
# DARWIN_PUSH_BROKERS=
# DARWIN_PUSH_TOPIC=
# DARWIN_KAFKA_*  (see Old Website darwin-local-test/.env.example)
