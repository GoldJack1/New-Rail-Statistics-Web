{
  "name": "rail-statistics-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=lib/index.js --packages=external --alias:@=../src",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "npm run build && firebase deploy --only functions:exportStationSnapshotsAfterPublish,functions:exportStationSnapshotsOnScheduledPublish,functions:exportStationSnapshotsManual"
  },
  "dependencies": {
    "firebase-admin": "^14.1.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3"
  }
}
