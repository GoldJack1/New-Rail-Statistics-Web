# Rail Statistics — Next.js environment variables
#
# Phase 1 note: none of these are actually read by the app yet. Firebase is not
# initialized in Phase 1 (no live auth/Firestore/Storage) — this file documents
# the renamed variable names ahead of Phase 2 wiring (see MIGRATION_PLAN.md §3).
#
# Vite's `VITE_*` client-exposed prefix becomes Next.js's `NEXT_PUBLIC_*`.
# Server-only secrets (Darwin) get no prefix and must only be read inside
# Route Handlers (app/api/**/route.ts), never in Client Components.

# --- Firebase (client-safe — Phase 2) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# --- Dev-only flags (client-safe, Phase 2) ---
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
NEXT_PUBLIC_USE_LOCAL_DATA_ONLY=false
NEXT_PUBLIC_LOCAL_DEV_LOGIN_BYPASS=false

# --- OSM tile / Nominatim proxy (Phase 1 — Route Handlers, no keys required) ---
# Toggle whether the Leaflet map calls the same-origin `/api/osm-tile` proxy
# (app/api/osm-tile/route.ts) instead of tile.openstreetmap.org directly.
# Unset = on in production builds, off in local dev (matches old VITE_USE_OSM_PROXY behaviour).
NEXT_PUBLIC_USE_OSM_PROXY=

# --- Darwin (server-only — Phase 2, NOT used in Phase 1) ---
# DARWIN_API_TOKEN=
